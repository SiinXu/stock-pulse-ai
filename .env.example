# ===================================
# StockPulse environment configuration template
# Copy this file to .env and enter the actual configuration.
# ===================================

# Watchlist (comma-separated; supports Shanghai and Shenzhen stock codes)
# Shanghai stocks: 600xxx, 601xxx, 603xxx
# Shenzhen stocks: 000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# Anspire Open API keys (multiple keys are supported, comma-separated)
# Obtain keys from: https://open.anspire.cn/
# When no higher-priority OpenAI-compatible source is configured, this key may also be used for the Anspire LLM gateway and news search.
# The following gateways and models are examples; consult the Anspire console and official documentation for current availability:
# Example gateway: https://open-gateway.anspire.cn/v6
# Example model: Doubao-Seed-2.0-lite (override with ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro)
# If the gateway differs by region or version, override it with ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# Data source configuration
# Tushare Pro Token (optional, obtained from https://tushare.pro/)
TUSHARE_TOKEN=
# TickFlow API Key (optional; used for A-shares daily K-line, real-time quotes, stock list/name and market review enhancement, automatic fallback if permission is insufficient)
# TICKFLOW_API_KEY=
# TICKFLOW_KLINE_ADJUST=none          # none/forward/backward/forward_additive/backward_additive
# TICKFLOW_BATCH_DAILY_ENABLED=true   # Batch pre-fetch daily K data through TickFlow when permission is granted.
# TICKFLOW_BATCH_SIZE=100             # Maximum number of securities in a single batch request for TickFlow

# AlphaSift stock screening integration (disabled by default; normally managed by the Web "Enable Stock Selection" button)
ALPHASIFT_ENABLED=false
# Switch instructions:
# - ALPHASIFT_ENABLED affects only the AlphaSift screening flow; it does not rewrite, migrate, or clear existing LITELLM_*/LLM_* configuration.
# - To disable/rollback, set ALPHASIFT_ENABLED to false; keep existing provider/base_url/custom headers with fallback semantics.
# - Compatibility reference (for operational verification): see the LiteLLM provider and OpenAI-compatible notes below; runtime uses the LiteLLM version pinned in requirements.txt.
ALPHASIFT_INSTALL_SPEC=git+https://github.com/ZhuLinsen/alphasift.git@9f522747caafd3c0b1ddb7e14d5cf44c8580b6cf
# Compatibility note:
# - ALPHASIFT_INSTALL_SPEC is used only when explicitly calling /api/v1/alphasift/install; it does not overwrite existing .env configuration automatically.
# - To use the new pin after an upgrade, remove the old variable from `.env`, rebuild dependencies, and restart the service; alternatively, set it to the default above and rebuild the backend.
# - Changing only this field in .env without reverting `requirements.txt` and `src/config.py` triggers an allow-list rejection (alphasift_install_spec_not_allowed).
# AlphaSift full market snapshot source priority; if not configured, DSA will automatically inject TUSHARE_TOKEN based on whether it is configured:
# - With TUSHARE_TOKEN: tushare,sina,efinance,akshare_em,em_datacenter
# - Without TUSHARE_TOKEN: sina,efinance,akshare_em,em_datacenter
# SNAPSHOT_SOURCE_PRIORITY=tushare,sina,efinance,akshare_em,em_datacenter
# (To stay consistent with runtime injection, leave this unset instead of fixing a value in this file.)
# AlphaSift third-party wrapper data source timeout guard; avoid slowing down the entire stock selection when efinance/AkShare/Baostock/Tushare/yfinance get stuck.
# - ALPHASIFT_SOURCE_CALL_TIMEOUT_SEC is a global fallback; setting it to 0/off/disabled can disable caller-side timeout.
# - The SNAPSHOT and Daily-specific values override the global value; their defaults are 60s and 20s.
# ALPHASIFT_SOURCE_CALL_TIMEOUT_SEC=
# ALPHASIFT_SNAPSHOT_CALL_TIMEOUT_SEC=60
# ALPHASIFT_DAILY_CALL_TIMEOUT_SEC=20
# AlphaSift Eastmoney direct connection request speed limit and random jitter; reduce connection jitter during continuous fallback/hotspot refresh.
# ALPHASIFT_EASTMONEY_MIN_INTERVAL_SEC=1.0
# ALPHASIFT_EASTMONEY_JITTER_SEC=0.3
# AlphaSift latest version supports last-good snapshots, daily historical data and industry/concept provider caching; DSA runtime defaults to the isolated cache directory under data/alphasift.
# If customization is needed, override the following paths; leaving them empty will not overwrite existing DSA configurations.
# ALPHASIFT_DATA_DIR=data/alphasift
# ALPHASIFT_FALLBACK_SNAPSHOT_PATH=data/alphasift/snapshot.last_good.json
# ALPHASIFT_DAILY_HISTORY_CACHE_DIR=data/alphasift/daily_history
# ALPHASIFT_INDUSTRY_PROVIDER_CACHE_DIR=data/alphasift/industry_provider_cache
# The AlphaSift industry/concept provider is disabled by default; enable akshare to provide more sector data for theme_heat, industry heat, and LLM context.
# INDUSTRY_PROVIDER=none
# INDUSTRY_PROVIDER_MAX_BOARDS=80
# The timeout seconds for a single LLM request; AlphaSift stock selection reuses DSA configuration, falls back to non-LLM sorting results after timeout.
# LLM_TIMEOUT_SEC=60
# AlphaSift LLM re-order request output limit; only affects AlphaSift stock selection re-ordering, default 2048.
# LLM_MAX_TOKENS=2048

# Finnhub (optional, U.S. stocks data source, free tier 60 calls/min)
# Get: https://finnhub.io/register
# FINNHUB_API_KEY=

# AlphaVantage (optional, U.S. stocks data source, free tier 25 calls/day)
# Get: https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI (optional, U.S. stocks/Hong Kong stocks volume ratio, turnover rate, PE fields fallback).
# Get from https://open.longbridge.com/
# OAuth 2.0 (recommended): First run scripts/generate_longbridge_oauth_token.py to generate local SDK token cache
# client_id takes LONGBRIDGE_OAUTH_CLIENT_ID priority; if empty and no Legacy Access Token is provided, use LONGBRIDGE_APP_KEY for compatibility
# GitHub Actions / Docker can base64 encode the token cache file and fill it into LONGBRIDGE_OAUTH_TOKEN_CACHE_B64
# LONGBRIDGE_OAUTH_CLIENT_ID=
# LONGBRIDGE_OAUTH_TOKEN_CACHE_B64=
# Legacy API key (for older accounts; Access Token is not an OAuth access token)
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# static_info process internal cache seconds, default 86400; 0=each request pulls
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# Cooling seconds after connection close exception; default 15; during the cooling period, Longbridge will temporarily be skipped to avoid request-level frequent reconnection.
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# Longbridge SDK language matches REPORT_LANGUAGE (zh/en); SDK logs written to LOG_DIR/longbridge_sdk.log.
# Access point (irrelevant to REPORT_LANGUAGE; leave empty to use the following default values):
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# Override endpoints; the SDK uses LONGPORT_REGION (without BRIDGE) internally for automatic selection,
# The code automatically syncs LONGBRIDGE_REGION → LONGPORT_REGION.
# hk → *.longbridge.com  |  cn → *.longbridge.cn
# For other options, see: https://open.longbridge.com/zh-CN/docs/getting-started
# Night trading market true/false, default false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K line push realtime or confirmed, default realtime.
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# Whether to print data packages when connecting (consistent with README / full-guide: defaults to off on the application side when not set, equivalent to false).
# Set to 1 / true / yes Enable SDK Detailed market data log(Use Longbridge connection debugging)
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# Stock Auto-completion Index Remote Update (default enabled; falls back to local built-in index if GitHub is inaccessible)
STOCK_INDEX_REMOTE_UPDATE_ENABLED=true

# ===================================
# AI model configuration
# ===================================
# Full instructions: docs/LLM_CONFIG_GUIDE.md
#
# [Quick Start]Just fill in an API Key to run, the system automatically identifies the model.
#   Anspire Open (one-stop model+search) → Fill ANSPIRE_API_KEYS
#   Gemini(free tier)→ Fill GEMINI_API_KEY
#   DeepSeek(High cost-effectiveness)→ Fill DEEPSEEK_API_KEY
#   AIHubmix(Aggregation Platform)→ Fill AIHUBMIX_KEY
#
# [Advanced]Requires multi-model/multi-platform fallback → configure 'Multi-Channel' below or visually manage in Web Settings.
# ===================================

# Generate backend: defaults to litellm; codex_cli / claude_code_cli / opencode_cli are explicit local CLI backends (experimental/limited).
# OpenCode CLI uses the default model from local OpenCode; OPENCODE_CLI_MODEL is just an optional --model override.
# Local CLI Backend is not equal to offline model, the service behind CLI may handle stock codes, news, holdings context, analysis prompt and report drafts.
# Docker / CI / remote server does not natively have desktop CLI login; DSA does not read Claude/OpenCode credential files.
# DSA uses the minimum allowlist env + provider credential denylist to reduce the risk of API keys / webhook tokens leakage.
# The quick check on the Web Settings page reads only configuration and executable visibility; the JSON test sends a real generation-backend smoke request.
GENERATION_BACKEND=litellm
# OPENCODE_CLI_MODEL=provider/model
# Backend-level fallback; Local .env empty values disable backend-level fallback, litellm -> litellm will be parsed as no-op.
# Default GitHub Actions workflow will explicitly use litellm when this variable is not configured; in Actions, set it to primary backend self no-op when disabling fallback.
GENERATION_FALLBACK_BACKEND=litellm
# Local CLI backend execution limit; timeout maximum 3600, output maximum 33554432 bytes, concurrent maximums are 16/4 respectively.
GENERATION_BACKEND_TIMEOUT_SECONDS=300
GENERATION_BACKEND_MAX_OUTPUT_BYTES=1048576
GENERATION_BACKEND_MAX_CONCURRENCY=1
LOCAL_CLI_BACKEND_MAX_CONCURRENCY=1
# Agent Chat backend; Web settings page only exposes auto/litellm, hand-written local CLI backend will return unsupported tool-calling diagnostics.
AGENT_GENERATION_BACKEND=auto

# --- API Key (fill one) ---

# Gemini（https://aistudio.google.com）
GEMINI_API_KEY=
# Multiple Key Load balancing: GEMINI_API_KEYS=key1,key2,key3

# DeepSeek（https://platform.deepseek.com）
# Compatibility default: Only fill in DEEPSEEK_API_KEY, still using deepseek-chat, and the logs will prompt migration to deepseek-v4-flash
# DEEPSEEK_API_KEY=

# AIHubmix Aggregation(https://aihubmix.com/)
# A Key using GPT/Claude/Gemini/GLM/Qwen models, without requiring VPN access
# AIHUBMIX_KEY=

# Anthropic Claude（https://console.anthropic.com）
# ANTHROPIC_API_KEY=

# OpenAI / Compatible API
# OPENAI_API_KEY=
# OPENAI_BASE_URL=                     # Third-party API address (proxy/relay), leave empty to use official.

# Ollama local model (no API Key required, recommended)
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b
#
# Or use channel mode:
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# Sampling temperature (0.0-2.0, default 0.7; 0 has the highest certainty, 2 has the highest randomness).
# Strict temperature compatibility from source:
# - Moonshot API / Model documentation: https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart
# - Moonshot official model card(evaluate default settings temperature = 1.0): https://huggingface.co/moonshotai/Kimi-K2.6
# - OpenAI Chat Completions specification: https://platform.openai.com/docs/api-reference/chat/create
# - LiteLLM OpenAI-compatible specification: https://docs.litellm.ai/docs/providers/openai_compatible
# Current repository runtime dependency constraints: litellm>=1.80.10,!=1.82.7,!=1.82.8,<2.0.0 (Explicitly exclude PyPI accident versions, see requirements.txt).
# Therefore, kimi-k2.6 will automatically switch to 1.0/0.6; default temperature models like GPT-5 / o series will omit temperature to avoid API rejection.
# If the target platform returns parameters that do not support errors explicitly, the parameter will be corrected and retried once within the current request; successful strategies only perform in-process caching.
# top_p, presence_penalty, frequency_penalty, seed If returns "Unsupported parameters", it will also trigger the request level correction and retry (without modifying LLM_TEMPERATURE).
# Other models and fallback still use your configured LLM_TEMPERATURE.
# Web settings page / Desktop import will not silently clear or rewrite LLM_TEMPERATURE; only temporarily adapts model parameters before sending a real request.
# If the main model switches back to the normal model, the originally configured temperature will automatically recover; the minimum rollback is to revert the change to the current LLM parameter adaptation.
# LLM_TEMPERATURE=0.7

# LLM usage telemetry message HMAC configuration (optional).
# If left blank, the system will generate a .llm_usage_hmac_secret in the data directory for local deployment, allowing for stable comparisons.
# Explicitly configure the same random key only when comparing usage message HMAC across deployments; synchronize update version tags during rotation.
# When explicitly configured, use a high-entropy random value (e.g., openssl rand -hex 32), do not commit real keys to version control.
# LLM_USAGE_HMAC_SECRET=
# LLM_USAGE_HMAC_KEY_VERSION=local-v1

# Provider prompt-cache configuration (optional)
# TELEMETRY only controls provider cache usage/diagnostics logging; does not control provider implicit cache.
# HINTS controls whether to actively send prompt_cache_key, cache_control, user_id and other provider-specific hints; defaults to disabled.
# DIAGNOSTICS_LEVEL can be off/basic/debug; debug only outputs de-identified diagnostics, not raw prompt or request body.
# LLM_PROMPT_CACHE_TELEMETRY_ENABLED=true
# LLM_PROMPT_CACHE_HINTS_ENABLED=false
# LLM_PROMPT_CACHE_DIAGNOSTICS_LEVEL=off

# --- Model Configuration Source Mode (Optional) ---
# auto(Default): Maintain historical priority YAML > Channels > Legacy provider keys.
# channels: only use LLM_CHANNELS; yaml: only use LITELLM_CONFIG; legacy: only use old provider keys.
# In non-auto mode, other sources' configurations will not be deleted, only inactive, making it easy to switch back.
# LLM_CONFIG_MODE=auto

# --- Multi-Channel Configuration (Optional, or Configurable in Web Settings Page) ---
# Each connection defines its own provider, base_url, api_key, and models. Multiple connections per provider are supported.
# LLM_<CONNECTION>_PROVIDER stores the catalog provider ID separately from the renameable connection name.
# Legacy entries infer a provider only when the connection name exactly matches a catalog ID; prefixes such as openai2 are never inferred.
#
# Example: DeepSeek + Gemini dual channels
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_PROVIDER=deepseek
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_GEMINI_PROVIDER=gemini
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview
#
# Example: Custom API endpoint (third-party proxy / aggregator / forwarding station)
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_PROVIDER=custom
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=sk-xxx
# LLM_MY_PROXY_MODELS=gpt-5.5,claude-sonnet-4-6
# LLM_MY_PROXY_PROTOCOL=openai
#
# Example: Ollama local models (no API Key required)
# LLM_CHANNELS=ollama
# LLM_OLLAMA_PROVIDER=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2
#
# Example: Hermes local HTTP generation (Phase 3, only basic analysis/JSON; does not support Agent tools, Stream, Vision)
# LLM_CHANNELS=hermes
# LLM_HERMES_PROVIDER=custom
# LLM_HERMES_PROTOCOL=openai
# LLM_HERMES_BASE_URL=http://127.0.0.1:8642/v1
# LLM_HERMES_API_KEY=sk-local-hermes
# LLM_HERMES_MODELS=hermes-agent
# LITELLM_MODEL=openai/hermes-agent
#
# Common vendor templates (select and copy to .env; see docs/llm-providers.md for full details)
#
# Anspire Open(shared search and LLM Key, OpenAI Compatible)
# LLM_CHANNELS=anspire
# LLM_ANSPIRE_PROVIDER=anspire
# LLM_ANSPIRE_PROTOCOL=openai
# LLM_ANSPIRE_BASE_URL=https://open-gateway.anspire.cn/v6  # Example
# LLM_ANSPIRE_API_KEY=sk-xxx
# LLM_ANSPIRE_MODELS=Doubao-Seed-2.0-lite,Doubao-Seed-2.0-pro  # Example models
# LITELLM_MODEL=openai/Doubao-Seed-2.0-lite  # Example
#
# AIHubmix Aggregation Platform(OpenAI Compatible)
# LLM_CHANNELS=aihubmix
# LLM_AIHUBMIX_PROVIDER=aihubmix
# LLM_AIHUBMIX_PROTOCOL=openai
# LLM_AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# LLM_AIHUBMIX_API_KEY=sk-xxx
# LLM_AIHUBMIX_MODELS=gpt-5.5,claude-sonnet-4-6,gemini-3.1-pro-preview
# LITELLM_MODEL=openai/gpt-5.5
#
# OpenAI Official
# LLM_CHANNELS=openai
# LLM_OPENAI_PROVIDER=openai
# LLM_OPENAI_PROTOCOL=openai
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_API_KEY=sk-xxx
# LLM_OPENAI_MODELS=gpt-5.5,gpt-5.4-mini
# LITELLM_MODEL=openai/gpt-5.5
#
# DeepSeek Official
# LLM_CHANNELS=deepseek
# LLM_DEEPSEEK_PROVIDER=deepseek
# LLM_DEEPSEEK_PROTOCOL=deepseek
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LITELLM_MODEL=deepseek/deepseek-v4-flash
#
# Gemini Official (official protocol, Base URL left blank)
# LLM_CHANNELS=gemini
# LLM_GEMINI_PROVIDER=gemini
# LLM_GEMINI_PROTOCOL=gemini
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview
# LITELLM_MODEL=gemini/gemini-3.1-pro-preview
#
# Anthropic Claude official (official agreement, Base URL left blank)
# LLM_CHANNELS=anthropic
# LLM_ANTHROPIC_PROVIDER=anthropic
# LLM_ANTHROPIC_PROTOCOL=anthropic
# LLM_ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-7
# LITELLM_MODEL=anthropic/claude-sonnet-4-6
#
# Kimi / Moonshot（OpenAI Compatible）
# LLM_CHANNELS=moonshot
# LLM_MOONSHOT_PROVIDER=moonshot
# LLM_MOONSHOT_PROTOCOL=openai
# LLM_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# LLM_MOONSHOT_API_KEY=sk-xxx
# LLM_MOONSHOT_MODELS=kimi-k2.6,kimi-k2.5
# LITELLM_MODEL=openai/kimi-k2.6
#
# Alibaba Cloud Qwen DashScope (OpenAI compatible)
# LLM_CHANNELS=dashscope
# LLM_DASHSCOPE_PROVIDER=dashscope
# LLM_DASHSCOPE_PROTOCOL=openai
# LLM_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_DASHSCOPE_API_KEY=sk-xxx
# LLM_DASHSCOPE_MODELS=qwen3.6-plus,qwen3.6-flash
# LITELLM_MODEL=openai/qwen3.6-plus
#
# Zhipu GLM (OpenAI compatible)
# LLM_CHANNELS=zhipu
# LLM_ZHIPU_PROVIDER=zhipu
# LLM_ZHIPU_PROTOCOL=openai
# LLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_ZHIPU_API_KEY=xxx
# LLM_ZHIPU_MODELS=glm-5.1,glm-4.7-flash
# LITELLM_MODEL=openai/glm-5.1
#
# MiniMax（OpenAI Compatible）
# Source: Official OpenAI API compatibility documentation https://platform.minimax.io/docs/api-reference/text-chat
# LiteLLM routes through openai/<model> to a Base URL compatible with Chat Completions.
# LLM_CHANNELS=minimax
# LLM_MINIMAX_PROVIDER=minimax
# LLM_MINIMAX_PROTOCOL=openai
# LLM_MINIMAX_BASE_URL=https://api.minimax.io/v1
# LLM_MINIMAX_API_KEY=xxx
# LLM_MINIMAX_MODELS=MiniMax-M2.7,MiniMax-M2.7-highspeed
# LITELLM_MODEL=openai/MiniMax-M2.7
#
# Xiaomi MiMo (OpenAI Compatible)
# Base URL and model name should refer to the official MiMo documentation/console.
# LLM_CHANNELS=mimo
# LLM_MIMO_PROVIDER=custom
# LLM_MIMO_PROTOCOL=openai
# LLM_MIMO_BASE_URL=https://your-mimo-endpoint.example/v1
# LLM_MIMO_API_KEY=sk-xxx
# LLM_MIMO_MODELS=mimo-xxx
# LITELLM_MODEL=openai/mimo-xxx
# Note: The default daily_analysis workflow in the repository is not explicitly passed through to LLM_MIMO_*, this example defaults to local .env, Docker, or self-hosted scripts; please synchronize the workflow mapping when using Actions.
#
# Volcengine Ark / Doubao (OpenAI compatible; adjust the endpoint for the actual region)
# Source: Volcengine Online Inference / Responses API Documentation https://www.volcengine.com/docs/82379/2121998
# LiteLLM routes through openai/<model> to a Base URL compatible with Chat Completions.
# LLM_CHANNELS=volcengine
# LLM_VOLCENGINE_PROVIDER=volcengine
# LLM_VOLCENGINE_PROTOCOL=openai
# LLM_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_VOLCENGINE_API_KEY=xxx
# LLM_VOLCENGINE_MODELS=doubao-seed-1-6-251015,doubao-seed-1-6-thinking-251015
# LITELLM_MODEL=openai/doubao-seed-1-6-251015
#
# SiliconFlow (OpenAI Compatible)
# Source: Official Model List https://docs.siliconflow.cn/quickstart/models
# LLM_CHANNELS=siliconflow
# LLM_SILICONFLOW_PROVIDER=siliconflow
# LLM_SILICONFLOW_PROTOCOL=openai
# LLM_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# LLM_SILICONFLOW_API_KEY=sk-xxx
# LLM_SILICONFLOW_MODELS=deepseek-ai/DeepSeek-V3.2,Qwen/Qwen3-235B-A22B-Thinking-2507
# LITELLM_MODEL=openai/deepseek-ai/DeepSeek-V3.2
#
# OpenRouter（OpenAI Compatible）
# Source: Official Models API https://openrouter.ai/docs/api/api-reference/models/get-models
# LLM_CHANNELS=openrouter
# LLM_OPENROUTER_PROVIDER=openrouter
# LLM_OPENROUTER_PROTOCOL=openai
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_API_KEY=sk-or-xxx
# LLM_OPENROUTER_MODELS=~anthropic/claude-sonnet-latest,~openai/gpt-latest
# LITELLM_MODEL=openai/~anthropic/claude-sonnet-latest

# Advanced: Model Routing YAML Configuration (optional, see docs/examples/litellm_config.example.yaml)
# LITELLM_CONFIG=./litellm_config.yaml

# ===================================
# Search engine configuration (for fetching stock news).
# ===================================
# Bocha API Keys (Chinese search optimization, supports AI summary, supports multiple, comma-separated)
# Get: https://open.bocha.cn/
# BOCHA_API_KEYS=your_bocha_key_here
# MiniMax API Key(Coding Plan Web Search, Supports multiple, Comma-separated)
# Get: https://platform.minimax.io/
# MINIMAX_API_KEYS=your_minimax_key_here
# Tavily API Keys (supports multiple, comma-separated)
TAVILY_API_KEYS=
# SerpAPI Keys (supports multiple, comma-separated)
SERPAPI_API_KEYS=
# Brave Search API Keys(Supports multiple, Comma-separated)
# Get: https://brave.com/search/api/
BRAVE_API_KEYS=
# SearXNG instance address (comma-separated, private deployments have no quotas; enable format: json in settings.yml)
# GitHub Actions daily analysis workflow supports variables with the same name first, Secrets fall back; public address can be configured as a variable.
# If left empty, it defaults to automatically pulling public instances from searx.space; if you do not want to access public instances, set the switch below to false.
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# ===================================
# Social Sentiment Intelligence (US stocks only)
# ===================================
# Reddit / X (Twitter) / Polymarket sentiment data from api.adanos.org
# Only activates for US stock tickers (AAPL, TSLA, etc.), ignored for A-shares/HK stocks
# Free tier: 250 requests/month | Register: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# News timeliness and analysis filtering configuration
# ===================================
# News strategy window position: ultra_short(1 day) / short(3 days) / medium(7 days) / long(30 days)
# Actual window = min(strategy window, NEWS_MAX_AGE_DAYS)
# NEWS_STRATEGY_PROFILE=short
# Maximum news timeliness (days), limit search results to recent periods, avoid using outdated information
# NEWS_MAX_AGE_DAYS=3
# News/intelligence pool retention period; only cleans intelligence_items, does not affect historical reports.
# NEWS_INTEL_RETENTION_DAYS=30
# RSS/Atom feed source pull timeout (seconds)
# NEWS_INTEL_FETCH_TIMEOUT_SEC=8
# Maximum number of items collected from each information source per request
# NEWS_INTEL_MAX_ITEMS_PER_SOURCE=50
# When enabled, automatically initialize built-in news sources and pull them into use before reading local news pools in individual stock analysis, Agent analysis, and market review;
# Default to disable, preventing unconfirmed external requests and analysis input changes
# Note: The default daily_analysis workflow in the repository is not explicitly passed through to this variable; please synchronize the workflow mapping when using Actions.
# NEWS_INTEL_AUTO_FETCH_ENABLED=false
# NewsNow HTTP API base address – external dependency configuration
# - Official project and deployment guide: https://github.com/qqhann/newsnow
# - The current default value https://newsnow.busiyi.world is a public example instance, which has the following risks:
#   * May be unavailable due to official maintenance or rate limiting.
#   * Not guaranteed stability or data reliability, only for demonstration and testing
# - Production environment strongly recommends switching to a self-hosted NewsNow instance to ensure controllability and stability
# - Before deployment, verify API contract compatibility (see docs/intelligence-sources.md):
#   curl -sS "https://newsnow.busiyi.world/api/s?id=cls-hot" | python -c "import sys, json; data=json.load(sys.stdin); assert isinstance(data.get('items'), list)"
# - This configuration only controls news source collection and cleanup behavior, without changing LLM / provider / base URL / compatibility rollback semantics
# NEWSNOW_BASE_URL=https://newsnow.busiyi.world
# bias ratio threshold (%), relax to 1.5 times for strong trend stocks if deviated from MA5 exceeds this value; it prompts not to chase highs.
# BIAS_THRESHOLD=5.0

# ===================================
# Agent strategy dialogue configuration (Web dialogue page)
# ===================================
# Enable Agent strategy conversation (default false, internally unified naming as skill)
# AGENT_MODE=true
# Agent main model (optional): Empty when inheriting from the main model; without provider prefix will parse as openai/<model>
# AGENT_LITELLM_MODEL=
# Agent maximum inference step limit (default 10, each sub-agent runs according to its preset value; higher than the default 10, all sub-agents use this value; below a sub-agent's default value will be capped)
# AGENT_MAX_STEPS=10
# Default enable strategy (comma-separated); uses default values below if not configured
#
# Built-in strategy skill list (can be combined arbitrarily):
#   bull_trend — Bull trend (MA5 > MA10 > MA20 arrangement + low bias ratio)
#   ma_golden_cross     — Moving-average golden cross (MA5 crosses above MA10/MA20)
#   volume_breakout — Volume breakout (price breaking recent high + increased trading volume)
#   hot_theme — hot theme (policy/industry hotspots, sector diffusion and individual stock correlation)
#   event_driven — Event-driven (driven by catalysts such as earnings, policies, orders, M&A etc.)
#   growth_quality — Growth quality (Revenue Profitability, ROE, Cash Flow and growth sustainability)
#   expectation_repricing — Expectation repricing (driven by earnings/policy/valuation gap repair or disappointment)
#   shrink_pullback — Shrink pullback (retrace of moving average + volume weakening, low-buying point)
#   bottom_volume — Bottom volume expansion (volume rises near the bottom, a bullish signal)
#   dragon_head — leading-stock strategy (strong leading stocks, trend continuation follow-up)
#   one_yang_three_yin — one bullish candle flanked by three bearish candles (a bullish breakout pattern after market cleanup)
#   box_oscillation — Box oscillation (range high bounce low absorption)
#   chan_theory — Chan Theory (stroke/segment/pivot analysis)
#   wave_theory — Elliott Wave Counting
#   emotion_cycle — Sentiment cycle (market sentiment high and low point rotation)
#
# If left empty, the system will use the default strategy skill declared in metadata (the built-in default is bull_trend).
# AGENT_SKILLS=
#
# You can also manually specify a set of strategies:
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
#
# Fully enable all built-in strategies (both ways are equivalent):
# AGENT_SKILLS=all
# AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,hot_theme,event_driven,growth_quality,expectation_repricing,shrink_pullback,bottom_volume,dragon_head,one_yang_three_yin,box_oscillation,chan_theory,wave_theory,emotion_cycle
#
AGENT_SKILLS=
# Custom strategy directory (optional, place custom YAML strategy files; environment variable name follows internal skill naming)
# AGENT_SKILL_DIR=./strategies

# Agent architecture mode (default single; multi is multi-agent orchestration mode)
# AGENT_ARCH=single

# Multi-agent orchestration mode (valid only when AGENT_ARCH=multi)
# quick: technical analysis → decision (fastest, approx. 2 LLM calls)
# standard: technology → intelligence → decision (default)
# full: Technology → Intelligence → Risk Control → Decision
# specialist: technology → intelligence → risk control → strategy expert assessment → decision
# AGENT_ORCHESTRATOR_MODE=standard

# Agent timeout budget (seconds; 0 disables it). In single-agent mode it is the overall loop budget; in multi-agent mode it is the orchestration budget. Default: 600.
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# Independent sub-agent timeout (seconds; 0 disables it). A positive value such as 180 sets a hard limit for that agent.
# Effective rules:
#   - When the pipeline budget is disabled (AGENT_ORCHESTRATOR_TIMEOUT_S=0), the sub-agent limit acts as that agent's absolute timeout.
#   - When the pipeline budget is enabled, the effective limit is min(remaining pipeline budget, sub-agent limit).
#   - With the default value (0), there is no independent limit; only the remaining pipeline budget applies.
# AGENT_TECHNICAL_AGENT_TIMEOUT_S=0
# AGENT_INTEL_AGENT_TIMEOUT_S=0
# AGENT_RISK_AGENT_TIMEOUT_S=0
# AGENT_DECISION_AGENT_TIMEOUT_S=0
# AGENT_PORTFOLIO_AGENT_TIMEOUT_S=0
# AGENT_SKILL_AGENT_TIMEOUT_S=0

# Can the risk control agent reject buy signals (default enabled)?
# AGENT_RISK_OVERRIDE=true

# Memory and calibration system (track historical accuracy, automatically adjust confidence)
# AGENT_MEMORY_ENABLED=false

# Automatically weight strategy opinions based on backtesting performance.
# AGENT_SKILL_AUTOWEIGHT=true

# Strategy routing mode (auto=select from market state / manual=use the AGENT_SKILLS list)
# AGENT_SKILL_ROUTING=auto

# AskStock visible dialogue context compression (default disabled). When enabled, only the user's visible historical data for user/assistant is compressed, without affecting cross-round tool/thinking transmission.
# AGENT_CONTEXT_COMPRESSION_ENABLED=false
# Compression profile: cost=use fewer tokens / balanced=balance both goals / long_context_raw_first=retain more original text
# AGENT_CONTEXT_COMPRESSION_PROFILE=balanced
# Trigger compressed historical token threshold; leave empty to follow the current profile preset
# AGENT_CONTEXT_COMPRESSION_TRIGGER_TOKENS=
# Keep the original round and its subsequent replies when compressing; leave empty if follow current profile preset
# AGENT_CONTEXT_PROTECTED_TURNS=

# Alarm event monitoring (scheduled background polling; reusable configured notification channels after triggering)
# Compatibility notes: This section only adds alert rule configuration, will not modify model name, provider, Base URL, LiteLLM or LLM configuration semantics; rollback only requires closing/removing event monitoring configuration.
# legacy JSON only supports three single-symbol basic rules; technical indicators, watchlists, holdings/account, and big red/green light rules should be configured via the Web/API alarm center.
# legacy JSON supports the following rules:
#   price_cross          — Price breaks threshold, direction: above / below, Field: price
#   price_change_percent — percentage change threshold, direction: up / down, field: change_pct (unit: %)
#   volume_spike — Increased trading volume, field: multiplier (relative to the past 20-day average multiple)
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800},{"stock_code":"300750","alert_type":"price_change_percent","direction":"down","change_pct":3.0},{"stock_code":"000858","alert_type":"volume_spike","multiplier":2.5}]
# ====== DingTalk Robot ======
# Webhook URL for DingTalk group robots
DINGTALK_WEBHOOK_URL=
# The signing key for the DingTalk robot (a string starting with 'SEC'), which can be empty if signing is not enabled.
DINGTALK_SECRET=
# ===================================
# Notification Channel Configuration (multiple can be configured simultaneously, all pushed)
# ===================================
#
# Method One: WeCom Robot
# In the WeCom group -> Settings -> Group Robot -> Add -> Copy Webhook Address
#
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
#
# Method Two: Feishu Robot (Choose one of two)
#
# Method 2a — Group Custom Robot Webhook
# In Feishu group -> Settings -> Group Bots -> Add Bot -> Custom Bot -> Copy Webhook Address
#
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key_here
# If the robot's security settings have 'signature verification' enabled, fill in the secret synchronously
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# If the robot's security settings have 'keyword' enabled, fill in the same keyword; the system will automatically prepend it to each message
# FEISHU_WEBHOOK_KEYWORD=StockPulse
#
# Method 2b — Feishu App Bot Push
# Create an application on the Feishu Open Platform, enable the im:message permission, and publish it.
#
# Chat mode (recommended): Pull the robot into the target group and get the chat_id from the group settings.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
#
# Private chat mode: Directly send private messages to a specified user. The user's open_id is obtained from the bot event or contact API.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=ou_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=open_id
# FEISHU_DOMAIN=feishu  # Domain: Feishu (domestic Feishu in China) / lark (international version larksuite.com)
#
# Method Three: Telegram Robot (Requires configuring both items simultaneously)
# 1. Find @BotFather in Telegram -> /newbot -> Get Bot Token
# 2. Get Chat ID: Send message to @userinfobot or visit https://api.telegram.org/bot<token>/getUpdates
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# [Method Four]Email Push (requires only 2 configurations, SMTP auto-recognition)
# Supports QQ email, 163 email, Gmail, etc. that support SMTP authorization code/basic authentication email
# Outlook / Exchange if tenant enforces OAuth2, this version does not currently support it
# 1. Get authorization code (example: QQ email): Settings -> Account -> POP3/SMTP service -> Enable -> Get authorization code
# 2. Enter the following two items:
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # Optional: Leave empty to send to yourself
#
# [Method Four Extended]Sending stock groups to different emails (Issue #268, optional)
# STOCK_LIST determines the actual analysis range; STOCK_GROUP_N only determines who emails are sent to, always write as a subset of STOCK_LIST
# Telegram / WeCom / Webhook etc. other channels will still push the complete STOCK_LIST in full, not split due to grouping
# The current repository default GitHub Actions daily_analysis workflow does not automatically inject any numbered STOCK_GROUP_N / EMAIL_GROUP_N
# This capability applies to local .env files, Docker, or other environments that have explicitly injected these variables
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# Custom Webhook (Supports multiple, comma-separated)
# Suitable for: DingTalk, Discord, Slack, Bark, and any service that supports POST JSON Webhooks.
# The system automatically identifies common services and uses corresponding formats
#
# CUSTOM_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=xxx,https://hooks.slack.com/services/xxx
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # Optional: For Webhooks requiring authentication (Header Authorization: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # Optional global JSON body template, overrides Bark/Slack/Discord etc. auto payloads; recommended $content_json/$title_json.
# When hand-writing .env in Docker Compose, write it as $$content_json/$$title_json; The Web settings page will automatically escape and restore to single $ at runtime
# WEBHOOK_VERIFY_SSL=true   # Default validation; affects webhook-style HTTPS notification requests reading this config. Set to false to support self-signed certificates. Warning: Disabling creates MITM interception risks, only for trusted internal networks
#
# Pushover Configuration
# Register Pushover account and create app Token https://pushover.net/apps/build
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
#
# ntfy Configuration
# NTFY_URL must contain topic path, e.g., https://ntfy.sh/my-topic or https://self-hosted:port/my-topic
# The system parses the topic and sends Markdown text using the ntfy JSON publish API.
# NTFY_URL=
# NTFY_TOKEN=  # Optional: For topics requiring a Bearer Token or self-hosted ntfy server
#
# Gotify Configuration
# GOTIFY_URL is the Gotify server base URL, without /message; the system will append /message and use the X-Gotify-Key Header to send the token.
# GOTIFY_URL=
# GOTIFY_TOKEN=  # Gotify application token
#
# Method Seven: PushPlus Configuration (Domestic Push Service, Recommended)
# Register PushPlus account and get Token https://www.pushplus.plus
# PUSHPLUS_TOKEN=
# Group push: Fill in the group code to send messages to all subscription users of the group (one-to-many).
# PUSHPLUS_TOPIC=
#
# Discord Configuration
# Supports two methods: Webhook (recommended, simple configuration) and Bot API (high permissions).
# 
# Method 1: Discord Webhook (recommended, no Bot account required)
# In Discord channel settings -> Integration -> Webhook -> Create Webhook -> Copy URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# 
# Method 2: Discord Bot API (requires Bot account and channel ID)
# 1. Create Bot: https://discord.com/developers/applications -> Create Application -> Bot -> Create Bot
# 2. Get Bot Token: Bot page -> Reset Token
# 3. Get channel ID: Enable developer mode in Discord -> Right-click channel -> Copy ID
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_CHANNEL_ID=   # Compatible with old variable names, recommended to use DISCORD_MAIN_CHANNEL_ID instead.
# DISCORD_MAX_WORDS=2000 # Discord content limit is 2000; automatically truncates to no more than 2000 and splits long reports for sending
# If you need to receive Discord Interaction / Webhook callbacks, you must configure the public key for verification.
# Get method: Discord Developer Portal -> General Information -> Public Key
# DISCORD_INTERACTIONS_PUBLIC_KEY=
# 
# Method Nine: Slack Configuration
# Supports two methods: Bot API (recommended) and Incoming Webhook.
# Prioritize using the Bot API when configuring simultaneously, ensuring text and images are sent to the same channel.
#
# Method 1: Slack Bot API (recommended, supports image uploads)
# 1. Create Slack App: https://api.slack.com/apps -> Create New App
# 2. Add Bot Token Scopes: chat:write, files:write
# 3. Install to workspace and get Bot Token (xoxb-...).
# 4. Get channel ID: Channel details -> Copy channel ID from the bottom.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
#
# Method 2: Slack Incoming Webhook (simple configuration, does not support image uploads)
# Create Incoming Webhook in Slack App Management Page -> Copy URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
#
# [Method ten]ServerSauce3 Configuration(Domestic push service, Supports WeChat push)
# Register Signal Panda 3 account and get SendKey https://sc3.ft07.com/
# SERVERCHAN3_SENDKEY=
#
# AstrBot Configuration
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # Optional for AstrBot Webhook requiring Bearer Token
#
# [Advanced Configuration]Message Length Limit (bytes)
# Automatically split into batches if exceeding limits, generally no need to modify
# FEISHU_MAX_BYTES=20000    # Feishu limits to approximately 20KB, default 20000 bytes
# FEISHU_SEND_AS_FILE=false # When set to true, Feishu sends reports in file format (App Bot mode), defaulting to text messages
# WECHAT_MAX_BYTES=4000     # WeCom limits 4096 bytes, default 4000 bytes
#
# [Markdown Convert to image](Issue #455)
# For channels that don't support Markdown, convert the report to an image for better readability.
# Stock push + images: Requires configuring MARKDOWN_TO_IMAGE_CHANNELS and installing the conversion tool.
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email,slack   # Comma-separated.
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000   # Do not convert if exceeding this length to avoid oversized images
# MD2IMG_ENGINE=wkhtmltoimage   # wkhtmltoimage (default) | markdown-to-file (emoji is better, install with npm i -g markdown-to-file)
# Image conversion tool: wkhtmltopdf (apt install wkhtmltopdf / brew install wkhtmltopdf), or markdown-to-file
#
# [Notification Routing Strategy](Issue #1200 P3)
# Leave blank: This type of notification is sent to all configured channels. Fill it in to send only to the listed configured channels.
# Allowed values: wechat, feishu, telegram, email, pushover, ntfy, gotify, pushplus, serverchan3, custom, discord, slack, astrbot
# NOTIFICATION_REPORT_CHANNELS=
# NOTIFICATION_ALERT_CHANNELS=
# NOTIFICATION_SYSTEM_ERROR_CHANNELS=
#
# [Notification Noise Reduction Mechanism](Issue #1200 P4)
# Default to disable all; only affects static notification channels, not robot session follow-up triggers.
# NOTIFICATION_DEDUP_TTL_SECONDS=0      # Only send one message for the same stable deduplication key within TTL; 0 disables
# NOTIFICATION_COOLDOWN_SECONDS=0       # Limit the frequency of the same cooling key within the window; 0 disables
# NOTIFICATION_QUIET_HOURS=             # Silent time period, format HH:MM-HH:MM, supports crossing midnight
# NOTIFICATION_TIMEZONE=                # Silent time zone, such as Asia/Shanghai; leave empty to follow TZ/system local time zone
# NOTIFICATION_MIN_SEVERITY=            # info,warning,error,critical; Leave blank to keep the status quo
# NOTIFICATION_DAILY_DIGEST_ENABLED=false  # Reserve configuration; daily summary will not be sent currently
#
# [Real-time Quote Pre-fetching](Issue #455)
# PREFETCH_REALTIME_QUOTES=true   # Set to false to disable, avoid full market pull from efinance/akshare_em; tushare is single-stock interface, prefetch only pulls the first stock

# ===================================
# (Optional) Single stock push configuration
# ===================================
# Single stock push mode: Pushes immediately after analyzing each stock, instead of pushing after aggregation
# SINGLE_STOCK_NOTIFY=false
#
# Report type: simple (concise), full (complete), brief (3-5 sentence summary)
# In a Docker environment, if content is not pushed completely, set it to full
# REPORT_TYPE=simple
# Report output language: zh(Chinese, default) / en(English) / ko(Korean)
# REPORT_LANGUAGE=zh
# Only analyze the result summary: when set to true, it only pushes summaries, without individual stock details
# REPORT_SUMMARY_ONLY=false
# The bottom of the notification report displays the name of the LLM model used in this analysis; set to false to hide it
# REPORT_SHOW_LLM_MODEL=true
#
# Report Engine P0 (Jinja2 / integrity check / Historical comparison)
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# Merge individual stock analysis and market review push (default false) to reduce email volume and lower the risk of spam emails
# MERGE_EMAIL_NOTIFICATION=false

# ===================================
# Analyze interval configuration (optional)
# ===================================
# Delay time (seconds) between individual stock analysis and major index analysis
# Avoids rate limits for Gemini and other AI APIs.
# ANALYSIS_DELAY=0

# Application AppKey (shared with Webhook mode)
DINGTALK_APP_KEY=xxxx
# AppSecret (shared with Webhook mode)
DINGTALK_APP_SECRET=xxxx
# Enable Stream mode
DINGTALK_STREAM_ENABLED=false

# Feishu app configuration (for App Bot active push / Stream Bot / Cloud Docs; does not directly enable group Webhook push)
FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx  # App Bot proactive push also requires FEISHU_CHAT_ID; prefer FEISHU_WEBHOOK_URL for simple group notifications
# App Bot proactively pushes targets; Stream Bot or Cloud Docs do not need this item
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
# Enable long connection mode
FEISHU_STREAM_ENABLED=false
# Feishu group robot Webhook security configuration (only used in Webhook push mode)
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# FEISHU_WEBHOOK_KEYWORD=StockPulse

# Database path
DATABASE_PATH=./data/stock_analysis.db
# SQLite Write Optimization: File Library defaults to enabling WAL, reducing lock contention during bulk writes and concurrent rollback operations
SQLITE_WAL_ENABLED=true
# SQLite Wait Lock Timeout (milliseconds)
SQLITE_BUSY_TIMEOUT_MS=5000
# Maximum retries when SQLite reports database is locked or database table is locked
SQLITE_WRITE_RETRY_MAX=3
# SQLite Write Retry Backoff Time (seconds, exponential backoff increment)
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# Analyze historical snapshot: Do not persist the entire context_snapshot when set to false
# Includes enhanced_context, market_phase_summary, AnalysisContextPack overview, diagnostics and raw snapshot fields
SAVE_CONTEXT_SNAPSHOT=true

# ===================================
# Backtesting configuration (optional)
# ===================================
# Enable backtesting (true/false)
BACKTEST_ENABLED=true
# Backtesting evaluation window (trading days)
BACKTEST_EVAL_WINDOW_DAYS=10
# only backtest analysis records of N days ago (to avoid incomplete data for that day/recently)
BACKTEST_MIN_AGE_DAYS=14
# Backtesting engine version (used to differentiate results when backtesting logic is upgraded).
BACKTEST_ENGINE_VERSION=v1
# Neutral range threshold (%), e.g., 2 represents -2%~+2% as a range-bound movement
BACKTEST_NEUTRAL_BAND_PCT=2.0

# === Scheduled Task Configuration ===
# Enable scheduled tasks (true/false)
SCHEDULE_ENABLED=false
# Daily execution time (HH:MM format, 24-hour clock)
SCHEDULE_TIME=18:00
# List execution over multiple time periods (comma-separated, use SCHEDULE_TIME if empty)
SCHEDULE_TIMES=
# Whether to immediately execute an analysis upon startup (true/false).
# If not explicitly set, the scheduled mode uses the runtime of RUN_IMMEDIATELY to maintain compatibility with old configurations.
SCHEDULE_RUN_IMMEDIATELY=true
# Whether to immediately execute an analysis when the non-time mode is started (true/false)
RUN_IMMEDIATELY=true
# Enable market review (true/false)
MARKET_REVIEW_ENABLED=true
# Inject the market summary into individual-stock prompts and enable conservative guardrails (true/false; enabled by default)
DAILY_MARKET_CONTEXT_ENABLED=true
# Main Market Review Market Region: cn(A-shares), hk(Hong Kong stocks), us(U.S. stocks), jp(Japanese stocks), kr(Korean stocks), both(all markets);
# Supports comma subsets (e.g., cn,us,kr); invalid values/empty values will revert to cn. cn/hk/us/jp/kr is suitable for users who only focus on a specific region.
# MARKET_REVIEW_REGION=cn
# Market-review index colors: green_up=green for gains and red for losses (default), red_up=red for gains and green for losses
# MARKET_REVIEW_COLOR_SCHEME=green_up

# ===================================
# Proxy configuration (optional)
# ===================================
# Enable proxy (true/false, default false)
# Effective only in the local development environment; GitHub Actions automatically skips.
USE_PROXY=false
# Proxy server address (default 127.0.0.1)
PROXY_HOST=127.0.0.1
# Proxy server port (default 10809)
PROXY_PORT=10809

# System configuration
# Log directory
LOG_DIR=./logs
# Log level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# LiteLLM internal log level (DEBUG/INFO/WARNING/ERROR/CRITICAL; default WARNING; temporarily set to DEBUG when troubleshooting internal streaming/routing details).
# LITELLM_LOG_LEVEL=WARNING
# Maximum number of concurrent threads (recommended to keep low concurrency to avoid bans)
MAX_WORKERS=3
# Enable debugging logs
DEBUG=false

# ===================================
# WebUI configuration (optional)
# ===================================
# Start WebUI by default (true/false; default false)
WEBUI_ENABLED=false
# WebUI listening address (default 127.0.0.1; Docker/cloud servers must be set to 0.0.0.0 to access externally, see docs/deploy-webui-cloud.md)
WEBUI_HOST=127.0.0.1
# WebUI listening port (default 8000)
WEBUI_PORT=8000
# Automatically build the frontend before starting the Web service (npm install && npm run build, default true)?
WEBUI_AUTO_BUILD=true
# Trust X-Forwarded-For to get the real IP under a single-layer trusted reverse proxy (e.g., Nginx → App), take the rightmost value for login rate limiting; in multi-level proxy/CDN scenarios, the key for rate limiting may degrade to edge proxy IP, need to evaluate additionally; when directly connected to the public network, maintain false anti-forgery
# TRUST_X_FORWARDED_FOR=false
# Frontend development proxy target. Used only by the Vite dev server in apps/dsa-web; production is unaffected.
# During `npm run dev`, /api requests are forwarded here. The default is http://127.0.0.1:8000.
# DSA_WEB_DEV_API_PROXY=http://127.0.0.1:8000

# ===================================
# Web login authentication (optional)
# ===================================
# Set to true to enable password protection; set an initial password for the web page on the first access, which can be modified in "System Settings > Change Password"
# If you forget your password, you can execute: python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24  # Session expiration (hours)

# ===========================================
# Image recognition of stock codes (Settings page "From Image")
# ===========================================
# Request timeout is 60 seconds; image size max 5MB
# Configure at least one of GEMINI_API_KEY, ANTHROPIC_API_KEY or OPENAI_API_KEY (Vision capability model)

# ===========================================
# Data Fetcher Priority Configuration
# ===========================================
# Lower number = higher priority (tried first)
# Default priorities: efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# For US stocks, set YFINANCE_PRIORITY=0 to use Yahoo Finance first

# EFINANCE_PRIORITY=0      # EastMoney (China) - default: 0
# EFINANCE_CALL_TIMEOUT=30 # Timeout (seconds) for efinance API calls; prevents indefinite hangs
#                          # when eastmoney hosts are unreachable. Default: 30
# AKSHARE_PRIORITY=1       # AkShare (China) - default: 1
# TUSHARE_PRIORITY=2       # Tushare Pro (China) - default: 2
# TICKFLOW_PRIORITY=2      # TickFlow (A-shares) - Default: 2; Optional, must be configured with TICKFLOW_API_KEY
# PYTDX_PRIORITY=2         # Tongdaxin (China) - default: 2
#
# Pytdx custom server (for intranet/deploy): use custom host instead of built-in public servers
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# Or multiple servers: PYTDX_SERVERS=ip1:port1,ip2:port2
# BAOSTOCK_PRIORITY=3      # Baostock (China) - default: 3
# YFINANCE_PRIORITY=4      # Yahoo Finance (Global) - default: 4

# Example: Prioritize Yahoo Finance for US stocks
# YFINANCE_PRIORITY=0
# EFINANCE_PRIORITY=99

# ===========================================
# Real-time quote data source priority configuration
# ===========================================
# Used to obtain real-time data such as volume ratio, turnover rate, P/E ratio, etc.
# Optional data source (comma-separated, tried in order):
#   - tencent: Tencent Finance, provides volume ratio/turnover rate/PE/PB, with stable single-stock queries (preferred)
#   - akshare_sina: Sina Finance, basic data, volume ratio, but very stable
#   - efinance: Eastmoney (efinance library), includes volume ratio; full-market pulls are easily blocked
#   - akshare_em: Eastmoney (akshare library), full data, full pull is easy to be blocked
#   - tickflow: TickFlow, optional; supports batch pre-fetching of current assets when priority is among the top two.
#   - tushare: Tushare Pro, requires 2000 points, comprehensive data (recommended for paid users)
#
# Default priority:tencent > akshare_sina > efinance > akshare_em
# If you have a Tushare Pro high-score account, prioritize tushare:
# REALTIME_SOURCE_PRIORITY=tickflow,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tushare,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# Enable real-time quotes (disabling uses historical closing prices for analysis)
# ENABLE_REALTIME_QUOTE=true

# Intraday technicals: when enabled, use real-time prices to calculate MAs and bullish alignment (Issue #234); otherwise use the previous close.
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# Enable chip distribution (this interface is unstable; disabling it is recommended for cloud deployments)
# ENABLE_CHIP_DISTRIBUTION=true

# Enable fundamental aggregation (new P0 capability)
# ENABLE_FUNDAMENTAL_PIPELINE=true

# Fundamentals aggregation performance and stability parameters (units: seconds)
# FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=8.0
# FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=8.0
# FUNDAMENTAL_RETRY_MAX=1
# FUNDAMENTAL_CACHE_TTL_SECONDS=120
# FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# ===========================================
# Portfolio P0: Import / Risk / Exchange rate fallback configuration
# ===========================================
# Idempotency responses are replayed only within this many days (1-3650).
# PORTFOLIO_IDEMPOTENCY_REPLAY_WINDOW_DAYS=7
# PORTFOLIO_RISK_CONCENTRATION_ALERT_PCT=35.0
# PORTFOLIO_RISK_DRAWDOWN_ALERT_PCT=15.0
# PORTFOLIO_RISK_STOP_LOSS_ALERT_PCT=10.0
# PORTFOLIO_RISK_STOP_LOSS_NEAR_RATIO=0.8
# PORTFOLIO_RISK_LOOKBACK_DAYS=180
# PORTFOLIO_FX_UPDATE_ENABLED=true

# Enable the Eastmoney interface patch when Eastmoney endpoints used by efinance/AkShare fail frequently (for example, RemoteDisconnected or connection closed)
# When enabled, inject NID token and random User-Agent to reduce the probability of being rate-limited by Eastmoney
# ENABLE_EASTMONEY_PATCH=false
