# Environment variable file (contains sensitive information, do not submit)
.env
.env.*
*.env
*.env.local
.env.*.local

# Testing file (may contain sensitive configuration)
# Only ignore temporary test_*.py scripts in the repository root directory; unit tests in the tests/ directory need to be under version control.
/test_*.py
/test.sh

# Local review and advanced routing configuration (may contain sensitive information or temporary analysis outputs).
/.codex
/.tmp
/review.md
/litellm_config.yaml
/litellm_config.*.yaml

