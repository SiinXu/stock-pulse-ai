# Use union to merge changelog strategies
# When multiple concurrent PRs are added to the end of [Unreleased], Git directly takes all lines from both ends without generating conflict markers.
# Suitable for append-only changelog files.
docs/CHANGELOG.md merge=union

# Fixed SQLite release dumps preserve the exact exported DDL used by schema digests.
tests/fixtures/schema_migrations/*.sql whitespace=-trailing-space

# Documentation image/design assets are binary. Keep GitHub review diffs from
# trying to decode moved binary files as UTF-8.
sources/**/*.ai binary
sources/**/*.gif binary
sources/**/*.ico binary
sources/**/*.jpg binary
sources/**/*.jpeg binary
sources/**/*.png binary
sources/**/*.psd binary
docs/assets/**/*.ai binary
docs/assets/**/*.gif binary
docs/assets/**/*.ico binary
docs/assets/**/*.jpg binary
docs/assets/**/*.jpeg binary
docs/assets/**/*.png binary
docs/assets/**/*.psd binary

# === Force LF File Type (kernel/system interpreter directly consumes) ===
# Shell Script(entrypoint.sh, Any .sh)
*.sh text eol=lf
*.bash text eol=lf

# Dockerfile (including multi-stage or variants)
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Makefile
Makefile text eol=lf

# Environment variable file (if directly sourced by shell)
.env text eol=lf

# === New: Binary Files (Prohibited Git modification and line/encoding changes) ===
# Certificates, keys etc. (if any)
*.pem binary
*.crt binary
*.key binary
*.p12 binary
