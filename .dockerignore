# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Ignore virtual environment
venv/
.venv/
env/
.env
.env.*
!.env.example
.env.local

# Ignore IDE
.idea/
.vscode/
*.swp
*.swo

# Ignore local repository, CI metadata, and build artifacts
.git/
.github/
.claude/reviews/
data/
logs/
reports/
*.log

# Ignore tests and documentation
tests/
test_*.py
*_test.py
docs/
*.md
!README.md

# Ignore frontend/desktop products that do not participate in Docker image builds
apps/dsa-desktop/
node_modules/
dist/
build/
coverage/
apps/dsa-web/node_modules/
apps/dsa-web/dist/
apps/dsa-web/build/
apps/dsa-web/coverage/
