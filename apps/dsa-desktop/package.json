{
  "name": "stockpulse-desktop",
  "version": "3.21.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.daily-stock-analysis.desktop",
    "productName": "StockPulse",
    "protocols": [
      {
        "name": "StockPulse",
        "schemes": [
          "stockpulse"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "local-model-catalog.js",
      "assistant-preload.js",
      "model-preload.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../../.env.example",
        "to": ".env.example"
      },
      {
        "from": "../../src/llm/local_model_catalog.json",
        "to": "local-model-catalog.json"
      },
      {
        "from": "../../dist/backend/stock_analysis",
        "to": "backend/stock_analysis"
      },
      {
        "from": "../../docs/assets/dsa_vi/lightlogo.iconset/icon_32x32.png",
        "to": "assistant-tray.png"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "stockpulse-windows-installer-v${version}.${ext}",
      "publish": [
        {
          "provider": "github",
          "owner": "SiinXu",
          "repo": "stock-pulse-ai"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "include": "installer.nsh"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
